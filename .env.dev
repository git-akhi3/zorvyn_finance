# ------------------------------------------------------------
# Development environment file
# Use with: APP_ENV=dev
# ------------------------------------------------------------

# Django core
SECRET_KEY=dev-only-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
LANGUAGE_CODE=en-us
TIME_ZONE=UTC
USE_I18N=True
USE_TZ=True
STATIC_URL=static/

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=assessment_dev
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# API docs
API_TITLE=Zorvyn Finance API (Dev)
API_DESCRIPTION=Development environment for Zorvyn Finance API.
API_VERSION=1.0.0-dev
SPECTACULAR_SERVE_INCLUDE_SCHEMA=False
SPECTACULAR_COMPONENT_SPLIT_REQUEST=True
SWAGGER_PERSIST_AUTH=True
SWAGGER_DISPLAY_REQUEST_DURATION=True
SWAGGER_FILTER=True

# Rate limits
THROTTLE_AUTH_REGISTER=20/min
THROTTLE_AUTH_LOGIN=40/min
THROTTLE_USERS_READ=240/min
THROTTLE_USERS_WRITE=120/min
THROTTLE_RECORDS_READ=480/min
THROTTLE_RECORDS_WRITE=240/min
THROTTLE_DASHBOARD_READ=240/min
